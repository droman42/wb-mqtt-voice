// Irene — intent orchestration: a recognised Intent to a handler. Render:
//   dot -Tpng docs/images/intent-orchestration.dot -o docs/images/intent-orchestration.png
digraph orch {
  rankdir=LR; bgcolor="white"; splines=spline; nodesep=0.4; ranksep=0.9;
  fontname="Helvetica"; labelloc=t; fontsize=15;
  label="Orchestration: a recognised intent is routed to its handler, then runs sync or fire-and-forget";
  node [fontname="Helvetica", fontsize=11, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#616161", arrowsize=0.7];

  intent   [label="Intent\nname · entities · confidence", fillcolor="#fff8e1", color="#f9a825"];
  orch     [label="IntentOrchestrator", fillcolor="#e8f5e8", color="#388e3c"];
  registry [label="IntentRegistry\nintent name → handler", fillcolor="#e3f2fd", color="#1976d2"];
  handler  [label="handler.execute(intent, context)", fillcolor="#e8f5e8", color="#388e3c"];
  result   [label="IntentResult\nsynchronous reply", fillcolor="#f3e5f5", color="#7b1fa2"];
  fnf      [label="fire-and-forget\ndetached task + instant ack", fillcolor="#f3e5f5", color="#7b1fa2"];

  intent -> orch -> registry -> handler;
  handler -> result [label="most commands"];
  handler -> fnf    [label="long-running\n(timer, playback)", style=dashed];

  // disambiguation
  prio [shape=note, fillcolor="#fffde7", color="#fbc02d", fontsize=9,
        label="When a command is ambiguous (“стоп”, “ещё”), domain priorities +\nthe room's running actions decide which handler owns it."];
  orch -> prio [style=dashed, color="#9e9e9e"];
  { rank=sink; prio; }
}
