// Irene — hexagonal architecture (ports & adapters). Render:
//   dot -Tpng docs/images/hexagon.dot -o docs/images/hexagon.png
// Shared palette (reused across all Irene diagrams):
//   domain  amber  fill #fff3e0 / line #ef6c00
//   core    blue   fill #e3f2fd / line #1976d2
//   app     green  fill #e8f5e8 / line #388e3c
//   adapter purple fill #f3e5f5 / line #7b1fa2
//   base    grey   fill #f5f5f5 / line #757575
digraph hexagon {
  rankdir=LR;
  bgcolor="white";
  splines=spline;
  nodesep=0.35; ranksep=0.9;
  fontname="Helvetica"; labelloc=t; fontsize=16;
  label="Irene — hexagonal architecture: every dependency points inward, across a port";

  node [fontname="Helvetica", fontsize=11, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#9e9e9e", arrowsize=0.7];

  // --- driving side (primary / left) ---
  subgraph cluster_drive {
    label="Driving adapters"; fontsize=12; color="#cfcfcf"; style=rounded; margin=12;
    inputs  [label="inputs\nCLI · web · ws · mic", fillcolor="#f3e5f5", color="#7b1fa2"];
    runners [label="runners\ncomposition root", fillcolor="#f3e5f5", color="#7b1fa2"];
  }

  // --- core + domain (center) ---
  subgraph cluster_core {
    label="Core"; fontsize=12; color="#90caf9"; style=rounded; margin=14;
    ports  [label="ports\ncore/interfaces", fillcolor="#e3f2fd", color="#1976d2"];
    engine [label="engine + managers\ninput · output · workflow · context", fillcolor="#e3f2fd", color="#1976d2"];
    domain [label="DOMAIN\nintents", shape=hexagon, fillcolor="#fff3e0", color="#ef6c00", penwidth=2.4, fontsize=13];
  }

  // --- application (orchestration) ---
  subgraph cluster_app {
    label="Application"; fontsize=12; color="#a5d6a7"; style=rounded; margin=12;
    components [label="components\ncapability services", fillcolor="#e8f5e8", color="#388e3c"];
    workflows [label="workflows\npipeline", fillcolor="#e8f5e8", color="#388e3c"];
  }

  // --- driven side (secondary / right) ---
  subgraph cluster_driven {
    label="Driven adapters"; fontsize=12; color="#cfcfcf"; style=rounded; margin=12;
    providers [label="providers\nASR · TTS · LLM · NLU · …", fillcolor="#f3e5f5", color="#7b1fa2"];
    outputs   [label="outputs\nconsole · ws · audio · bridge", fillcolor="#f3e5f5", color="#7b1fa2"];
  }

  base [label="utils (foundation)  ·  config", fillcolor="#f5f5f5", color="#757575", width=4.4];

  // dependencies (inward). Adapters/app depend on the ports; ports face the domain.
  inputs     -> ports;
  runners    -> ports;
  components -> ports;
  workflows  -> ports;
  providers  -> ports  [dir=back];   // core drives providers through the port
  outputs    -> ports  [dir=back];   // core drives outputs through the port
  ports      -> domain [style=dashed, label="implemented\ninward", color="#1976d2", fontcolor="#1976d2"];
  engine     -> domain;
  engine     -> ports  [style=invis];

  // foundation is used by all, depends on nothing
  { rank=sink; base; }
  domain -> base [style=dotted, color="#bdbdbd", label="uses", fontcolor="#9e9e9e"];
}
