# Target profile: WB7 — Irene deployed on a Wiren Board 7 controller (embedded-armv7 image).
# This is the "remote" mode: the SUT is already running on the controller; tests just point
# at it. Edit the host below to your controller, or override per-run:
#   make ws TARGET=wb7 WS_AUDIO_URL=ws://192.168.1.50:8080/ws/audio HEALTH_URL=http://192.168.1.50:8080/health
WS_AUDIO_URL=ws://wirenboard.local:8080/ws/audio
HEALTH_URL=http://wirenboard.local:8080/health
MQTT_HOST=wirenboard.local
MQTT_PORT=1883
EXECUTE_URL=http://192.168.110.250:8080/execute/command
BRIDGE_CAPTURE_URL=http://192.168.110.250:8010/_captured
