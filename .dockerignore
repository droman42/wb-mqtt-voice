# Keep the Docker build context lean (the context is the repo ROOT for all images) and keep secrets
# out of it. The Dockerfiles COPY only: backend/src/, backend/pyproject.toml, backend/uv.lock,
# config/, assets/, README.md, docker/. Everything below is excluded from what's sent to the daemon.

# Secrets — NEVER in an image layer (.env holds DEEPSEEK_API_KEY etc.)
.env
.env.*
!.env.example

# Version control
.git
.github
.gitignore

# Virtual environments (the 6 GB dev venv — now backend/.venv under src-layout; **/ covers both)
**/.venv
.venv
venv/
env/
ENV/

# Node / the config-ui app (not used by any image)
**/node_modules
config-ui/

# Docs, dev scripts, local build tooling
docs/
scripts/
*.egg-info/

# Python caches & test/type tooling
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*

# Runtime artifacts (never in the build context)
logs/
data/
traces/
*.log
*.db
*.sqlite3

# Editors / OS cruft
.vscode/
.idea/
*.swp
.DS_Store
